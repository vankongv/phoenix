# ── Required ──────────────────────────────────────────────────
# GitHub Personal Access Token — needs repo + pull_request write scope
GITHUB_TOKEN=your-github-pat-here

# Anthropic API key — used by /refine and as the default LLM for /runs
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional ──────────────────────────────────────────────────
# Port the agent service binds to (default: 8001). Set this to avoid conflicts
# with other processes already using port 8001. Must be an integer in 1–65535.
# AGENT_PORT=8001

# Default LLM model passed to OpenHands (overridable per-agent from the UI)
# LLM_MODEL=anthropic/claude-opus-4-6

# Comma-separated allowed CORS origins for production deployments.
# Leave unset for local dev (defaults to all localhost ports).
# CORS_ORIGINS=https://your-frontend.example.com

# Directory where base repo clones are kept (default: ~/.pnx/repos)
# PNX_REPOS_DIR=/var/lib/ponenix/repos

# ── Semantic service (semantic_server.py) ─────────────────────
# Minimum TF-IDF cosine similarity to surface a duplicate (0-1, default 0.15)
# SIMILARITY_THRESHOLD=0.15

# How long (seconds) to cache fetched issues per repo (default 300 = 5 min)
# CACHE_TTL_SECONDS=300

# Max issues fetched per repo for similarity comparison (default 500)
# MAX_ISSUES=500

# Port for the semantic service (default 3001)
# PORT=3001
