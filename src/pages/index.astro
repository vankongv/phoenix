---
import AppHeader from '../components/AppHeader.astro';
import Sidebar from '../components/Sidebar.astro';
import BoardToolbar from '../components/BoardToolbar.astro';
import TokenModal from '../components/TokenModal.astro';
import NewIssueModal from '../components/NewIssueModal.astro';
import IssueDrawer from '../components/IssueDrawer.astro';
import AgentsPanel from '../components/AgentsPanel.astro';
import AgentRail from '../components/AgentRail.astro';
import TeamsPanel from '../components/TeamsPanel.astro';
import SettingsPanel from '../components/SettingsPanel.astro';
import PlanningPanel from '../components/PlanningPanel.astro';
import RunHistoryPanel from '../components/RunHistoryPanel.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Phoenix — GitHub Kanban</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  </head>
  <body>
    <AppHeader />

    <div class="flex flex-1 overflow-hidden">
      <Sidebar />

      <main class="flex-1 flex flex-col overflow-hidden">
        <BoardToolbar />

        <div class="flex-1 overflow-auto">
          <!-- empty -->
          <div
            id="empty-state"
            class="flex flex-col items-center justify-center h-full gap-3 text-center px-6"
          >
            <div
              class="w-14 h-14 rounded-xl flex items-center justify-center mb-1"
              style="background:#dae2ff"
            >
              <span class="material-symbols-outlined text-primary" style="font-size:28px"
                >view_kanban</span
              >
            </div>
            <h2 class="font-semibold text-base text-on-surface">GitHub Kanban</h2>
            <p class="text-xs text-on-surface-variant max-w-xs leading-relaxed">
              Enter an <span class="text-primary font-mono">owner/repo</span> in the sidebar and hit Load
              to pull issues into a Kanban board.
            </p>
          </div>

          <!-- loading -->
          <div id="loading-state" class="hidden flex-col items-center justify-center h-full gap-4">
            <div style="background:#edeef0" class="rounded-xl px-5 py-4 flex items-center gap-3">
              <span
                class="material-symbols-outlined text-primary animate-spin"
                style="font-size:22px">autorenew</span
              >
              <div>
                <p class="text-sm font-medium text-on-surface" id="loading-text">
                  Fetching issues…
                </p>
                <p class="text-[11px] text-on-surface-variant mt-0.5">Talking to GitHub API</p>
              </div>
            </div>
          </div>

          <!-- error -->
          <div
            id="error-state"
            class="hidden flex-col items-center justify-center h-full gap-3 text-center px-6"
          >
            <div style="background:#edeef0" class="rounded-xl px-5 py-4 max-w-sm">
              <span class="material-symbols-outlined text-error text-2xl mb-2 block"
                >error_outline</span
              >
              <p class="text-sm font-medium text-on-surface mb-1" id="error-text">
                Something went wrong
              </p>
              <p class="text-xs text-on-surface-variant" id="error-detail"></p>
            </div>
          </div>

          <!-- board -->
          <div id="board-wrap" class="hidden p-5">
            <div id="board" class="board-scroll"></div>
          </div>
        </div>
      </main>
    </div>

    <TokenModal />
    <NewIssueModal />
    <IssueDrawer />
    <AgentsPanel />
    <AgentRail />
    <TeamsPanel />
    <SettingsPanel />
    <PlanningPanel />
    <RunHistoryPanel />

    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
