---

---

<div style="background:#edeef0" class="flex items-center gap-2 px-5 h-11 flex-shrink-0">
  <span id="board-repo" class="font-mono text-[11px] text-secondary uppercase tracking-wider"
  ></span>
  <div class="flex-1"></div>
  <div class="relative">
    <span
      class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-on-surface-variant"
      style="font-size:14px">search</span
    >
    <input
      id="filter-search"
      type="text"
      placeholder="Search…"
      class="bg-surface-container-lowest pl-8 pr-3 py-1.5 text-xs text-on-surface placeholder:text-on-surface-variant/40 rounded-lg w-40"
      style="border:1px solid rgba(195,198,214,0.5)"
    />
  </div>
  <select
    id="filter-label"
    class="bg-surface-container-lowest px-2 py-1.5 text-[11px] text-on-surface-variant rounded-lg"
    style="border:1px solid rgba(195,198,214,0.5)"
  >
    <option value="">All labels</option>
  </select>
  <select
    id="filter-assignee"
    class="bg-surface-container-lowest px-2 py-1.5 text-[11px] text-on-surface-variant rounded-lg"
    style="border:1px solid rgba(195,198,214,0.5)"
  >
    <option value="">All assignees</option>
  </select>
  <button
    id="new-issue-btn"
    class="hidden items-center gap-1 text-[11px] font-semibold text-on-primary px-3 py-1.5 rounded-lg transition-all active:scale-95"
    style="background:linear-gradient(135deg,#003d9b,#0052cc)"
  >
    <span class="material-symbols-outlined" style="font-size:13px">add</span>
    New Issue
  </button>
</div>
